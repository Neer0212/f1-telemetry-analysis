# FastF1 cache (large, regenerable — never commit)
cache/
.fastf1/

# Generated outputs (charts/reports are reproducible from scripts)
outputs/charts/*
outputs/reports/*
!outputs/charts/.gitkeep
!outputs/reports/.gitkeep
outputs/models/
outputs/reports/season_*.csv

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Editor/OS
.vscode/
.idea/
.DS_Store
*.swp
